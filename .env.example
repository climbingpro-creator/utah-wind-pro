# Utah Wind Pro - Environment Variables
# Copy this file to .env and fill in your API keys

# ── Weather Data ─────────────────────────────────────────────────

# Synoptic (MesoWest) API — https://synopticdata.com/
VITE_SYNOPTIC_TOKEN=your_synoptic_token_here
SYNOPTIC_TOKEN=your_synoptic_token_here

# Ambient Weather API — https://ambientweather.net/
VITE_AMBIENT_API_KEY=your_ambient_api_key_here
VITE_AMBIENT_APP_KEY=your_ambient_application_key_here
VITE_AMBIENT_DEVICE_MAC=your_device_mac_here

# ── Supabase (Auth + Database) ───────────────────────────────────
# Create a project at https://supabase.com/

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Stripe (Subscriptions) ──────────────────────────────────────
# Create an account at https://stripe.com/

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ── Upstash Redis (Server-Side Caching) ─────────────────────────

UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Push Notifications (Web Push / VAPID) ─────────────────────
# Generate with: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_MAILTO=mailto:hello@utahwindfinder.com
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ── Cron Authentication ────────────────────────────────────────
# Required for cron job endpoints (collect, push-check)

CRON_SECRET=your_cron_secret_here

# ── Server-Side API Keys (no VITE_ prefix — never exposed to client) ──

AMBIENT_API_KEY=your_ambient_api_key_here
AMBIENT_APP_KEY=your_ambient_application_key_here

# ── Optional ─────────────────────────────────────────────────────

VITE_API_ORIGIN=https://utah-wind-pro.vercel.app
VITE_SMS_ENDPOINT=https://your-sms-provider.com/send

# ── Weather Underground PWS Network ─────────────────────────────
# Free for PWS owners: 1,500 calls/day, 30/min
# Register at https://www.wunderground.com/member/api-keys
WU_API_KEY=your_wu_api_key_here

# ── Gemini (AI Biology Agent) ────────────────────────────────────
# Powers /api/biology — dynamic species/forage profiles for any water body
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
