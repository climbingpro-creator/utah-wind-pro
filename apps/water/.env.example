# Synoptic Data (MesoWest) API token
VITE_SYNOPTIC_TOKEN=

# Ambient Weather API credentials
VITE_AMBIENT_API_KEY=
VITE_AMBIENT_APP_KEY=

# Cross-app routing: URL to the Wind companion app
VITE_WIND_APP_URL=https://liftforecast.com

# API Origin: Where the /api/* serverless routes live
# For notwindy.com, this should point to the main API deployment
VITE_API_ORIGIN=

# PMTiles Water Data URL
# Options:
#   1. Local file in public folder (Utah regional POC): /utah-water.pmtiles
#   2. Supabase Storage: https://your-project.supabase.co/storage/v1/object/public/map-data/file.pmtiles
#   3. Cloudflare R2: https://your-bucket.r2.cloudflarestorage.com/file.pmtiles
#
# Generate Utah PMTiles: node scripts/generate-utah-pmtiles.mjs
# For local testing, use the generated file in apps/water/public/:
VITE_PMTILES_WATER_URL=/utah-water.pmtiles
#
# For production (Supabase example):
# VITE_PMTILES_WATER_URL=https://euoprueicxuoeuffpxwz.supabase.co/storage/v1/object/public/map-data/global-water.pmtiles

# OpenAI API Key (for synthesize-reports.js LLM pipeline)
OPENAI_API_KEY=

# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
