{
  "name": "@utahwind/wind",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:init": "cap init",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "mobile:build": "npm run build && cap sync",
    "mobile:android": "npm run build && cap sync android && cap open android",
    "mobile:ios": "npm run build && cap sync ios && cap open ios",
    "mobile:dev:android": "cap run android --configuration=capacitor.config.dev.json",
    "mobile:dev:ios": "cap run ios --configuration=capacitor.config.dev.json",
    "generate:assets": "capacitor-assets generate --iconBackgroundColor #0f172a --splashBackgroundColor #0f172a --ios --android"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@utahwind/database": "*",
    "@utahwind/ui": "*",
    "@utahwind/weather": "*",
    "axios": "^1.13.6",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.21.1",
    "pmtiles": "^4.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.0",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@utahwind/config": "*",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  }
}
