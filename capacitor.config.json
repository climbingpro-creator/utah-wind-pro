{
  "appId": "com.utahlakewindpro.app",
  "appName": "UtahWindFinder",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "url": "https://utah-wind-pro.vercel.app",
    "cleartext": false
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f172a"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f172a",
      "showSpinner": false,
      "androidSpinnerStyle": "small",
      "spinnerColor": "#06b6d4"
    }
  },
  "ios": {
    "contentInset": "automatic"
  },
  "android": {
    "allowMixedContent": true
  }
}
