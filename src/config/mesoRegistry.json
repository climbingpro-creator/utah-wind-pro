{
  "METADATA": {
    "version": "1.0",
    "description": "Meso-relational spatial mapping: which gates and indicators affect which locations. Multipliers refine base predictions when upstream sensors confirm active patterns."
  },
  "RELATIONS": {
    "utah-lake-zigzag": {
      "name": "Saratoga Springs / Zig Zag",
      "thermal_engine": {
        "generator": "GREAT_SALT_LAKE",
        "upstream_gate": "KSLC",
        "indicator_type": "GSL_SURGE",
        "description": "NW wind from Great Salt Lake accelerates through Point of the Mountain gap",
        "min_temp_delta": 8,
        "wind_heading": [280, 360],
        "min_speed": 8,
        "multiplier": 1.25
      },
      "canyon_boost": {
        "source": "SPANISH_FORK_CANYON",
        "gate_sensor": "QSF",
        "description": "SE canyon drainage funnels into lake thermal — 2hr lead time",
        "heading": [100, 180],
        "speed_range": [6, 18],
        "multiplier": 1.15
      },
      "valley_confirmation": {
        "sensor": "UTALP",
        "description": "Point of Mountain confirms north flow is reaching the lake",
        "heading": [315, 45],
        "min_speed": 5,
        "multiplier": 1.10
      }
    },

    "utah-lake-lincoln": {
