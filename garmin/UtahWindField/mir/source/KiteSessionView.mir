using Toybox.Activity;
//! Kiteboarding Session Dashboard — 4-Zone Proportional Layout
//!
//! Designed for round Garmin displays (Fenix 7/7S/7X, Epix, FR965, etc.).
//! ALL coordinates use dynamic math off dc.getWidth()/getHeight() so the
//! layout scales from a 42 mm Fenix 7S (260 px) to a 51 mm Epix Pro (416 px).
//!
//!   ╭──────────────────────────────╮
//!   │  ZONE 1 — TOP ARC           │  clock + API warning
//!   │  12:45 PM     ⚠ DANGER      │
//!   │──────────────────────────────│
//!   │  ZONE 2 — CENTER ENGINE     │
//!   │          18.3                │  live speed (massive)
//!   │     kts   ♥142   top 22.1   │  unit + HR + top speed
//!   │──────────────────────────────│
//!   │  ZONE 3 — FLANKS            │
//!   │  ▲12.4 ft   JUMPS 7  1.6s  │  height | count | hang
//!   │  MAX 18.1       AVG 10.3    │
//!   │──────────────────────────────│
//!   │  ZONE 4 — BOTTOM GRID       │
//!   │  2.4 NM  │ 01:23:45 │  342  │  dist | timer | cal
//!   ╰──────────────────────────────╯
